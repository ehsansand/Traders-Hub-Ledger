rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // User document path with associated sub-collections
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /rialEntries/{entryId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /cryptoEntries/{cryptoId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
